{
  "enableSmartQuotes": false,
  "openingQuote": "«",
  "closingQuote": "»",
  "textReplacementRules": [
    {
      "from": "<<",
      "to": "«"
    },
    {
      "from": ">>",
      "to": "»"
    },
    {
      "from": "<=",
      "to": "≤"
    },
    {
      "from": ">=",
      "to": "≥"
    },
    {
      "from": "!=",
      "to": "≠"
    },
    {
      "from": "1/3",
      "to": "⅓"
    },
    {
      "from": "3/4",
      "to": "¾"
    },
    {
      "from": "1/2",
      "to": "½"
    },
    {
      "from": "1/4",
      "to": "¼"
    },
    {
      "from": "2/3",
      "to": "⅔"
    },
    {
      "from": "1/8",
      "to": "⅛"
    }
  ],
  "autoPairingRules": [
    {
      "open": "«",
      "close": "»"
    }
  ]
}